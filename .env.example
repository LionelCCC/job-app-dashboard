# ============================================================
# Job Application Pipeline Dashboard — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ------ Anthropic API (Required for ATS scoring & resume editing) ------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------ Optional: Job Search APIs (improves job discovery) ------
# RapidAPI key for JSearch (LinkedIn + Indeed aggregator)
# Get one free at: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your-rapidapi-key-here

# ------ Database ------
DATABASE_URL=sqlite:///./jobs.db

# ------ App Settings ------
# Directory paths (defaults work if you run from project root)
RESUMES_DIR=./resumes/uploaded
EDITED_RESUMES_DIR=./resumes/edited
SCREENSHOTS_DIR=./screenshots

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
